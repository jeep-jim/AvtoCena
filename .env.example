NEXT_PUBLIC_APP_URL=https://avtocena.com
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=avtocena_bot

# Telegram bot / Mini App
TELEGRAM_BOT_TOKEN=
# Chat ID владельца/служебной группы, куда бот отправляет заявки на партнёрский доступ.
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_BOT_SECRET=

# Auth
# Обязательно поменять на проде. Используется для подписи cookies.
AUTH_SECRET=change_me_long_random_string
# Если заполнить, форма /login будет требовать этот ключ вместе с Telegram username.
AUTH_ACCESS_KEY=

# CPA
# Секрет для входа на закрытую страницу /partner/api?key=...
CPA_DOCS_KEY=
# Секрет для редких входящих callback от CPA-сетей. Основной статусный поток идёт исходящим S2S.
CPA_POSTBACK_SECRET=
# Секрет для cron/служебного запуска повторной доставки POST /api/cpa/deliver.
CPA_DELIVERY_SECRET=
CPA_API_SECRET=

# DaData: подсказки городов и определение города по IP.
# Можно использовать DADATA_TOKEN вместо DADATA_API_KEY.
DADATA_API_KEY=

# JSON storage driver: local for dev, object for Yandex Object Storage in production
JSON_STORAGE_DRIVER=local
YC_OBJECT_STORAGE_ENDPOINT=https://storage.yandexcloud.net
YC_OBJECT_STORAGE_REGION=ru-central1
YC_OBJECT_STORAGE_BUCKET=
YC_OBJECT_STORAGE_ACCESS_KEY_ID=
YC_OBJECT_STORAGE_SECRET_ACCESS_KEY=
YC_OBJECT_STORAGE_PREFIX=crm
