{
  "name": "avtocena",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/bot",
    "packages/engine"
  ],
  "scripts": {
    "dev": "npm --workspace=@avtocena/web run dev",
    "dev:web": "npm --workspace=@avtocena/web run dev",
    "dev:bot": "npm --workspace=@avtocena/bot run dev",
    "build": "npm --workspace=@avtocena/web run build",
    "clean:web": "node -e \"require('fs').rmSync('apps/web/.next',{recursive:true,force:true})\"",
    "dev:fresh": "npm run clean:web && npm run dev",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "npm --workspace=@avtocena/web exec tsc -- --noEmit && npm --workspace=@avtocena/engine exec tsc -- --noEmit",
    "storage:migrate-to-object": "tsx scripts/storage-migrate-to-object.mjs",
    "catalog:import": "tsx scripts/catalog-import.mjs",
    "catalog:smoke": "tsx scripts/catalog-smoke.mjs",
    "catalog:import:sample": "CATALOG_ENCAR_DIRECT_PAGE_SIZE=20 CATALOG_MAX_IMAGES_PER_OFFER=3 tsx scripts/catalog-import-sample.mjs"
  }
}
